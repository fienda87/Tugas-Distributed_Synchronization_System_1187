# Core
ROLE=lock
NODE_ID=lock_a
HTTP_PORT=9000

# Cluster
CLUSTER_NODES=http://lock_a:9000,http://lock_b:9001,http://lock_c:9002
CLUSTER_PEERS=http://queue_a:9100,http://queue_b:9101,http://queue_c:9102
REDIS_URL=redis://redis:6379/0

# Raft
RAFT_ELECTION_MIN_MS=1500
RAFT_ELECTION_MAX_MS=3000
RAFT_HEARTBEAT_MS=80

# Queue
QUEUE_REPLICA_FACTOR=2
QUEUE_VISIBILITY_MS=25000

# Cache
CACHE_CAPACITY=512
CACHE_DEFAULT_TTL_MS=60000

# Security
AUTH_ENABLED=true
API_KEYS=demo_admin:admin,demo_writer:writer,demo_reader:reader
INTERNAL_API_KEY=demo_admin
AUDIT_LOG_PATH=/data/audit.log
AUDIT_HASH_PATH=/data/audit.hash

# Inter-node encryption
INTER_NODE_ENC=true
ENC_SHARED_KEY_BASE64=2xQq0M0pB1jU1m8eY2QGhr0n6B7aB23ChzldnKmv3g0=

# Geo routing
REGION=ap-south
REGION_MAP=ap-south:220,eu-west:280,us-east:320

# ML balancer
BALANCER_SAMPLE_MS=3000
